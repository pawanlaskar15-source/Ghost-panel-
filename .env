# ═══════════════════════════════════════════════════════════════════
# ALONExRAJ Panel — Environment Variables
# Copy this file or set these in Railway/Render ENV settings
# ═══════════════════════════════════════════════════════════════════

# ─── REQUIRED ─────────────────────────────────────────────────────

# Panel login credentials (owner account)
OWNER_USER=Ghost
OWNER_PASS=Ghost@1234

# MongoDB connection string (get from MongoDB Atlas free tier)
MONGO_URI=mongodb+srv://flushi3693694_db_user:150qCqkKFkWlT2bh@cluster0.wdfotef.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGO_DB_NAME=alonexraj_panel

# ─── OPTIONAL (defaults shown) ────────────────────────────────────

# Flask secret key (auto-generated if empty)
FLASK_SECRET_KEY=GHOST_DDOS_2026_SUPER_SECRET_KEY_123456

# Server port (Railway/Render set this automatically)
PORT=3000

# Debug mode (NEVER true in production)
FLASK_DEBUG=False

# Credit system: how many credits = 1 hour of key time
CREDITS_PER_HOUR=10

# Rate limiter settings
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SEC=300
LOGIN_LOCKOUT_SEC=900

# Keep-alive ping (set to true to disable on paid plans)
DISABLE_KEEP_ALIVE=false
